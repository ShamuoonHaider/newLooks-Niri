* {
    bg:       #1e1e2e;
    bg-alt:   #313244;
    fg:       #cdd6f4;
    accent:   #cba6f7;
    background-color: @bg;
    text-color: @fg;
    font: "JetBrainsMono Nerd Font 12";
}
window {
    width: 50%;
    border-radius: 12px;
    background-color: @bg;
}
mainbox {
    padding: 12px;
}
inputbar {
    background-color: @bg-alt;
    border-radius: 8px;
    padding: 8px 12px;
    margin-bottom: 12px;
    children: [prompt, entry];
}
prompt {
    text-color: @accent;
    padding: 5px 15px 5px 10px;
    margin: 0;
}
entry{
    padding: 5px 10px;
}
listview {
    columns: 2;
    lines: 6;
    spacing: 4px;
    fixed-height: true;
}
element {
    padding: 8px 12px;
    border-radius: 6px;
    orientation: horizontal;
}
element selected {
    background-color: @accent;
    text-color: @bg;
}
element-icon {
    size: 32px;
    margin: 0 8px 0 0;
}
element-text {
    background-color: transparent;
    text-color: inherit;
    vertical-align: 0.5;
}
